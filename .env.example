# Copy this file to .env.local and fill in values for local development.
# NEVER commit .env.local or any file containing real credentials.
#
# Pass values to flutter run with:
#   flutter run \
#     --dart-define=MEDPLUM_CLIENT_ID=your_client_id \
#     --dart-define=MEDPLUM_CLIENT_SECRET=your_secret
#
# For CI (GitHub Actions), add both as repository secrets:
#   Settings → Secrets and variables → Actions → New secret
#     MEDPLUM_CLIENT_ID
#     MEDPLUM_CLIENT_SECRET

MEDPLUM_CLIENT_ID=
MEDPLUM_CLIENT_SECRET=
